# ============================================================================
# Template Environment Configurations (Commit Safe)
# Instructions: Copy this file to '.env' and fill in your actual credentials.
# ============================================================================

# User ID to run Airflow containers (helps align volume permissions on Linux)
AIRFLOW_UID=50000

# PostgreSQL Operational Database Configs
POSTGRES_HOST=postgres
POSTGRES_DB=ecommerce_events
POSTGRES_USER=your_db_user_here
POSTGRES_PASSWORD=your_secure_password_here

# Airflow Web UI Admin User Credentials
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=admin_password

# Airflow Core Configurations
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
